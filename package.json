{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vue-tsc && vite build && vite build --ssr",
        "build:ssr": "vue-tsc && vite build && vite build --ssr && vite build && vite build --ssr --ssr",
        "dev": "vite",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "types:check": "vue-tsc --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "@laravel/vite-plugin-wayfinder": "^0.1.3",
        "@rushstack/eslint-patch": "^1.8.0",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@tailwindcss/forms": "^0.5.3",
        "@types/node": "^22.13.5",
        "@vue/eslint-config-prettier": "^9.0.0",
        "@vue/eslint-config-typescript": "^14.0.0",
        "@vue/server-renderer": "^3.4.0",
        "autoprefixer": "^10.4.12",
        "eslint": "^9.19.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-vue": "^9.23.0",
        "postcss": "^8.4.31",
        "prettier": "^3.3.0",
        "prettier-plugin-organize-imports": "^4.0.0",
        "prettier-plugin-tailwindcss": "^0.6.5",
        "typescript-eslint": "^8.23.0",
        "vue-tsc": "^2.0.24"
    },
    "dependencies": {
        "@inertiajs/vite": "^3.0.0",
        "@inertiajs/vue3": "^3.0.0",
        "@tailwindcss/vite": "^4.1.11",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vueuse/core": "^12.8.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "tailwind-merge": "^3.2.0",
        "tailwindcss": "^4.1.1",
        "typescript": "^5.6.3",
        "vite": "^8.0.0",
        "vue": "^3.5.13"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-arm64-gnu": "^4.0.0",
        "@rollup/rollup-linux-x64-gnu": "4.9.5",
        "@tailwindcss/oxide-linux-arm64-gnu": "^4.0.1",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.0.1",
        "lightningcss-linux-arm64-gnu": "^1.29.1",
        "lightningcss-linux-x64-gnu": "^1.29.1"
    },
    "pnpm": {
        "supportedArchitectures": {
            "cpu": ["arm64", "x64"],
            "os": ["linux", "darwin"]
        }
    }
}
